# =============================================================================
# GET ME A CHAI - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Get Me A Chai
NEXT_PUBLIC_APP_DESCRIPTION=AI-Powered Crowdfunding Platform
SUPPORT_EMAIL=support@getmeachai.com
NOREPLY_EMAIL=noreply@getmeachai.com

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/get-me-a-chai
# Or use MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Optional: Database connection pool settings
# DB_MAX_POOL_SIZE=10
# DB_MIN_POOL_SIZE=2
# DB_TIMEOUT=5000

# -----------------------------------------------------------------------------
# AUTHENTICATION (NextAuth.js)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-here-change-in-production
# Generate with: openssl rand -base64 32

# Session settings
# SESSION_MAX_AGE=2592000  # 30 days in seconds

# -----------------------------------------------------------------------------
# OAUTH PROVIDERS
# -----------------------------------------------------------------------------

# GitHub OAuth
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret

# Google OAuth
GOOGLE_ID=your_google_client_id
GOOGLE_SECRET=your_google_client_secret

# Demo Account (for testing)
DEMO_EMAIL=demo@getmeachai.com
DEMO_PASSWORD=demo123456
DEMO_ENABLED=true

# -----------------------------------------------------------------------------
# PAYMENT GATEWAY (Razorpay)
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Payment settings
PAYMENT_CURRENCY=INR
PAYMENT_MIN_AMOUNT=1  # ₹1
PAYMENT_MAX_AMOUNT=9999999  # ₹99,99,999 (Razorpay limit is < 1 billion paise)

# -----------------------------------------------------------------------------
# AI CONFIGURATION (OpenRouter)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key
# Get your key from: https://openrouter.ai/

# Optional: AI settings
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=deepseek/deepseek-r1
# AI_MAX_TOKENS=2000
# AI_TEMPERATURE=0.7

# AI Rate Limiting
# AI_RATE_LIMIT_MAX=20
# AI_RATE_LIMIT_WINDOW=3600000  # 1 hour in ms

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
# For Gmail: https://support.google.com/accounts/answer/185833

SMTP_FROM_NAME=Get Me A Chai
SMTP_FROM_EMAIL=noreply@getmeachai.com

# Email feature flags
EMAIL_ENABLED=true
EMAIL_SEND_WELCOME=true
EMAIL_SEND_RECEIPTS=true
EMAIL_SEND_WEEKLY_SUMMARY=true

# -----------------------------------------------------------------------------
# CRON JOBS
# -----------------------------------------------------------------------------
CRON_SECRET=your_cron_secret_key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

CRON_ENABLED=true
CRON_WEEKLY_DAY=1  # Monday
CRON_WEEKLY_HOUR=9  # 9 AM

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true

# Authentication endpoints
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=900000  # 15 minutes

# API endpoints
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW=900000  # 15 minutes

# General endpoints
RATE_LIMIT_GENERAL_MAX=1000
RATE_LIMIT_GENERAL_WINDOW=900000  # 15 minutes

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=DEBUG  # DEBUG, INFO, WARN, ERROR
LOG_PRETTY_PRINT=true

# -----------------------------------------------------------------------------
# FILE UPLOAD
# -----------------------------------------------------------------------------
UPLOAD_MAX_FILE_SIZE=5242880  # 5MB in bytes

# -----------------------------------------------------------------------------
# CAMPAIGN SETTINGS
# -----------------------------------------------------------------------------
CAMPAIGN_MIN_GOAL=1000  # ₹1,000
CAMPAIGN_MAX_GOAL=100000000  # ₹10 Crore
CAMPAIGN_MIN_DURATION=7  # days
CAMPAIGN_MAX_DURATION=90  # days

# -----------------------------------------------------------------------------
# ANALYTICS
# -----------------------------------------------------------------------------
ANALYTICS_ENABLED=true
ANALYTICS_TRACK_VIEWS=true
ANALYTICS_TRACK_EVENTS=true

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
CORS_ORIGINS=*  # Comma-separated list of allowed origins
CSRF_ENABLED=true
HELMET_ENABLED=true

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
FEATURE_AI_CAMPAIGN_BUILDER=true
FEATURE_AI_CHATBOT=true
FEATURE_AI_RECOMMENDATIONS=true
FEATURE_SUBSCRIPTIONS=true
FEATURE_SOCIAL_SHARING=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_PUSH_NOTIFICATIONS=false

# -----------------------------------------------------------------------------
# EXTERNAL SERVICES (Optional)
# -----------------------------------------------------------------------------
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# SENTRY_DSN=your_sentry_dsn
# GOOGLE_ANALYTICS_ID=your_ga_id
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Cloudinary (for image uploads)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
